{
  "// aima game starter": "Press F5 to build (preLaunchTask) then debug the selected CMake launch target. program is resolved by CMake Tools from the active preset + selected target, so it tracks the preset (windows-debug / mac-arm64-debug / linux-x64-debug) and the aima_game target automatically — never hardcode the path.",
  "version": "0.2.0",
  "configurations": [
    {
      "// note": "macOS / lldb (native arm64 via the mac-arm64-debug preset). Uses the cpptools lldb backend.",
      "name": "Launch aima_game (macOS / lldb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "MIMode": "lldb",
      "preLaunchTask": "CMake: build"
    },
    {
      "name": "Launch aima_game (Windows / MSVC)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "environment": [
        {
          "name": "PATH",
          "value": "${command:cmake.launchTargetDirectory};${env:PATH}"
        }
      ],
      "console": "integratedTerminal",
      "preLaunchTask": "CMake: build"
    },
    {
      "// note": "Linux / gdb.",
      "name": "Launch aima_game (Linux / gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${command:cmake.launchTargetDirectory}",
      "MIMode": "gdb",
      "preLaunchTask": "CMake: build"
    }
  ]
}
